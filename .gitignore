# Python-Bytecode-Cache (wird beim Start automatisch neu erzeugt)
__pycache__/
*.py[cod]

# Generierte Sprite-Vorschau / Build-Artefakte aus tools/generate_assets.py
assets/sprites/preview.png

# Persönlicher Spielstand (lokal, nicht versionieren)
save.json

# Video-Aufnahmen (lokal behalten, nicht ins Repo)
media/clips/
*.mp4

# Treiber-Screenshots aus dem run-Skill (werden bei jedem Lauf neu erzeugt)
.claude/skills/*/shots/

# Slot-Speicherstände (wie save.json: lokale Spielerdaten)
save_slot*.json

# Generierte/Quell-Sprite-PNGs — Master liegen extern ("aselfmade assets"), nicht im Repo.
# _static = Quell-Standbilder für tools/animate_walk.py (nie zur Laufzeit geladen);
# _shot/_cast = Geschoss-/Cast-Sprites (geladen, aber Goldpfeil-Fallback). Das Spiel
# läuft lokal weiter (Dateien bleiben auf der Platte); frische Clones nutzen Fallbacks.
assets/custom/*_static.png
assets/custom/*_shot.png
assets/custom/*_cast.png
